<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Nellie.App"
             xmlns:local="using:Nellie"
             RequestedThemeVariant="Dark">
             <!-- Nellie ships a dark look for now; a full theming/skin system comes later. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>