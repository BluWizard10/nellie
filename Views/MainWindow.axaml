<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Nellie.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="620"
        x:Class="Nellie.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="960" Height="620"
        MinWidth="640" MinHeight="420"
        Background="#0F0F17"
        Title="Nellie">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="Accent" Color="#7C5CFF"/>
        <SolidColorBrush x:Key="AccentDim" Color="#5E48CC"/>
        <SolidColorBrush x:Key="Surface" Color="#161623"/>
        <SolidColorBrush x:Key="SurfaceAlt" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#ECECF4"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#9A9AB4"/>
        <SolidColorBrush x:Key="Divider" Color="#26263A"/>

        <!-- Transport / media icons (Material Design geometry, 24x24) -->
        <StreamGeometry x:Key="PlayIcon">M8,5v14l11,-7z</StreamGeometry>
        <StreamGeometry x:Key="PauseIcon">M6,19h4V5H6v14z M14,5v14h4V5h-4z</StreamGeometry>
        <StreamGeometry x:Key="StopIcon">M6,6h12v12H6z</StreamGeometry>
        <StreamGeometry x:Key="PrevIcon">M6,6h2v12H6z M9.5,12l8.5,6V6z</StreamGeometry>
        <StreamGeometry x:Key="NextIcon">M6,18l8.5,-6L6,6v12z M16,6v12h2V6h-2z</StreamGeometry>
        <StreamGeometry x:Key="ShuffleIcon">M10.59,9.17L5.41,4L4,5.41l5.17,5.17L10.59,9.17z M14.5,4l2.04,2.04L4,18.59L5.41,20L17.96,7.46L20,9.5V4H14.5z M14.83,13.41l-1.41,1.41l3.13,3.13L14.5,20H20v-5.5l-2.04,2.04L14.83,13.41z</StreamGeometry>
        <StreamGeometry x:Key="RepeatIcon">M7,7h10v3l4,-4l-4,-4v3H5v6h2V7z M17,17H7v-3l-4,4l4,4v-3h12v-6h-2V17z</StreamGeometry>
        <StreamGeometry x:Key="MusicIcon">M12,3v10.55c-0.59,-0.34,-1.27,-0.55,-2,-0.55c-2.21,0,-4,1.79,-4,4s1.79,4,4,4s4,-1.79,4,-4V7h4V3H12z</StreamGeometry>
        <StreamGeometry x:Key="VolumeIcon">M3,9v6h4l5,5V4L7,9H3z M16.5,12c0,-1.77,-1.02,-3.29,-2.5,-4.03v8.05c1.48,-0.73,2.5,-2.25,2.5,-4.02z</StreamGeometry>
        <StreamGeometry x:Key="SettingsIcon">M19.14,12.94c0.04,-0.3,0.06,-0.61,0.06,-0.94c0,-0.32,-0.02,-0.64,-0.07,-0.94l2.03,-1.58c0.18,-0.14,0.23,-0.41,0.12,-0.61l-1.92,-3.32c-0.12,-0.22,-0.37,-0.29,-0.59,-0.22l-2.39,0.96c-0.5,-0.38,-1.03,-0.7,-1.62,-0.94L14.4,2.81c-0.04,-0.24,-0.24,-0.41,-0.48,-0.41h-3.84c-0.24,0,-0.43,0.17,-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22,-0.08,-0.47,0,-0.59,0.22L2.74,8.87C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14,-0.23,0.41,-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39,-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.04,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44,-0.17,0.47,-0.41l0.36,-2.54c0.59,-0.24,1.13,-0.56,1.62,-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59,-0.22l1.92,-3.32c0.12,-0.22,0.07,-0.47,-0.12,-0.61L19.14,12.94z M12,15.6c-1.98,0,-3.6,-1.62,-3.6,-3.6s1.62,-3.6,3.6,-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z</StreamGeometry>
        <StreamGeometry x:Key="CloseIcon">M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12z</StreamGeometry>
    </Window.Resources>

    <Window.Styles>
        <!-- Toolbar text buttons -->
        <Style Selector="Button.tool">
            <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.tool:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A40"/>
        </Style>

        <!-- Round transport buttons -->
        <Style Selector="Button.transport">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="CornerRadius" Value="21"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.transport:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#242438"/>
        </Style>

        <!-- Primary play/pause button -->
        <Style Selector="Button.play">
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="CornerRadius" Value="28"/>
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.play:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentDim}"/>
        </Style>

        <!-- Toggle-state buttons (shuffle / repeat) go accent when active -->
        <Style Selector="Button.toggle.active">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
        </Style>

        <!-- Playlist DataGrid -->
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="SeparatorBrush" Value="{StaticResource Divider}"/>
        </Style>
        <Style Selector="DataGridRow">
            <Setter Property="MinHeight" Value="46"/>
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Settings scrim: stays constant on hover/press -->
        <Style Selector="Button.scrim /template/ ContentPresenter">
            <Setter Property="Background" Value="#99000000"/>
        </Style>

        <Style Selector="TextBlock.title">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="TextBlock.sub">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ============ Toolbar ============ -->
        <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,12"
                BorderBrush="{StaticResource Divider}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="Nellie" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    <Border Background="{StaticResource Accent}" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="MUSIC" FontSize="10" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button Classes="tool" Command="{Binding AddFilesCommand}" Content="Add Files"/>
                    <Button Classes="tool" Command="{Binding AddFolderCommand}" Content="Add Folder"/>
                    <Button Classes="tool" Command="{Binding ClearPlaylistCommand}" Content="Clear"/>
                    <Button Classes="transport" Command="{Binding OpenSettingsCommand}" ToolTip.Tip="Settings">
                        <PathIcon Data="{StaticResource SettingsIcon}" Width="20" Height="20"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ Playlist (dynamic, pattern-driven columns) ============ -->
        <DataGrid Grid.Row="1"
                  Name="PlaylistGrid"
                  ItemsSource="{Binding Playlist}"
                  SelectedItem="{Binding SelectedTrack}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  CanUserReorderColumns="False"
                  CanUserResizeColumns="True"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  Background="Transparent"
                  Sorting="OnPlaylistSorting"
                  DoubleTapped="OnPlaylistDoubleTapped"/>

        <!-- ============ Transport bar ============ -->
        <Border Grid.Row="2" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Divider}" BorderThickness="0,1,0,0"
                Padding="16,12">
            <Grid ColumnDefinitions="*,2*,*" VerticalAlignment="Center">

                <!-- Now playing -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="52" Height="52" CornerRadius="8" ClipToBounds="True"
                            Background="{StaticResource SurfaceAlt}">
                        <Panel>
                            <PathIcon Data="{StaticResource MusicIcon}" Width="22" Height="22"
                                      Foreground="{StaticResource TextSecondary}"
                                      IsVisible="{Binding CurrentArtwork, Converter={x:Static ObjectConverters.IsNull}}"/>
                            <Image Source="{Binding CurrentArtwork}" Stretch="UniformToFill"/>
                        </Panel>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="2" MaxWidth="180">
                        <TextBlock Classes="title" Text="{Binding CurrentTrack.Title, FallbackValue='Nothing playing'}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Classes="sub" Text="{Binding CurrentTrack.Artist}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>

                <!-- Controls + seek -->
                <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <Button Classes="transport toggle" Classes.active="{Binding Shuffle}"
                                Command="{Binding ToggleShuffleCommand}" ToolTip.Tip="Shuffle">
                            <PathIcon Data="{StaticResource ShuffleIcon}" Width="18" Height="18"/>
                        </Button>
                        <Button Classes="transport" Command="{Binding PreviousCommand}" ToolTip.Tip="Previous">
                            <PathIcon Data="{StaticResource PrevIcon}" Width="22" Height="22"/>
                        </Button>
                        <Button Classes="play" Command="{Binding PlayPauseCommand}" ToolTip.Tip="Play / Pause">
                            <Panel>
                                <PathIcon Data="{StaticResource PlayIcon}" Width="24" Height="24"
                                          IsVisible="{Binding !IsPlaying}"/>
                                <PathIcon Data="{StaticResource PauseIcon}" Width="24" Height="24"
                                          IsVisible="{Binding IsPlaying}"/>
                            </Panel>
                        </Button>
                        <Button Classes="transport" Command="{Binding NextCommand}" ToolTip.Tip="Next">
                            <PathIcon Data="{StaticResource NextIcon}" Width="22" Height="22"/>
                        </Button>
                        <Button Classes="transport toggle" Classes.active="{Binding IsRepeatActive}"
                                Command="{Binding CycleRepeatCommand}" ToolTip.Tip="Repeat">
                            <Panel>
                                <PathIcon Data="{StaticResource RepeatIcon}" Width="18" Height="18"/>
                                <Border Background="{StaticResource Accent}" CornerRadius="6"
                                        Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        IsVisible="{Binding IsRepeatOne}">
                                    <TextBlock Text="1" FontSize="9" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Panel>
                        </Button>
                    </StackPanel>

                    <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                        <TextBlock Grid.Column="0" Classes="sub" Text="{Binding PositionText}"
                                   VerticalAlignment="Center" Width="44" TextAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="{Binding DurationSeconds}"
                                Value="{Binding PositionSeconds}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Classes="sub" Text="{Binding DurationText}"
                                   VerticalAlignment="Center" Width="44" TextAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- Volume -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource VolumeIcon}" Width="18" Height="18"
                              Foreground="{StaticResource TextSecondary}"/>
                    <Slider Minimum="0" Maximum="1" Value="{Binding Volume}" Width="120" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ Settings slide-over ============ -->
        <Grid Grid.Row="0" Grid.RowSpan="3" IsVisible="{Binding IsSettingsOpen}">
            <!-- Scrim closes the panel when clicked -->
            <Button Classes="scrim" Command="{Binding CloseSettingsCommand}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    BorderThickness="0" CornerRadius="0"/>

            <Border Width="440" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                    Background="{StaticResource Surface}" Padding="24"
                    BorderBrush="{StaticResource Divider}" BorderThickness="1,0,0,0">
                <StackPanel Spacing="18">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Settings" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Classes="transport"
                                Command="{Binding CloseSettingsCommand}" ToolTip.Tip="Close">
                            <PathIcon Data="{StaticResource CloseIcon}" Width="18" Height="18"/>
                        </Button>
                    </Grid>

                    <Border Background="{StaticResource SurfaceAlt}" CornerRadius="10" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="FILE NAMING PATTERN" Classes="sub"/>
                            <TextBox Text="{Binding PatternText}"
                                     FontFamily="Cascadia Code,Consolas,monospace"
                                     PlaceholderText="{}{artist} - {song} [{label}]"/>
                            <TextBlock Classes="sub" TextWrapping="Wrap"
                                       Text="Use {token} placeholders separated by the literal text in your filenames (spaces, dashes, brackets). The playlist columns update to match your tokens."/>
                            <Border Background="{StaticResource Surface}" CornerRadius="6" Padding="10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="PREVIEW" Classes="sub" FontSize="10"/>
                                    <TextBlock Text="{Binding PatternPreview}" TextWrapping="Wrap"
                                               Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

</Window>
